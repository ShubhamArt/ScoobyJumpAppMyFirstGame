<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:startColor="#FAFAFA"
                android:endColor="#BDBDBD"
                android:angle="270" />
            <stroke android:width="2dp" android:color="#E0E0E0" />
        </shape>
    </item>
    <!-- Left Eye White -->
    <item android:gravity="left|center_vertical" android:left="12dp" android:width="12dp" android:height="18dp">
        <shape android:shape="oval"><solid android:color="#FFFFFF"/></shape>
    </item>
    <!-- Right Eye White -->
    <item android:gravity="right|center_vertical" android:right="12dp" android:width="12dp" android:height="18dp">
        <shape android:shape="oval"><solid android:color="#FFFFFF"/></shape>
    </item>
    <!-- Left Pupil -->
    <item android:gravity="left|center_vertical" android:left="16dp" android:width="8dp" android:height="8dp" android:top="2dp">
        <shape android:shape="oval"><solid android:color="#000000"/></shape>
    </item>
    <!-- Right Pupil -->
    <item android:gravity="right|center_vertical" android:right="16dp" android:width="8dp" android:height="8dp" android:top="2dp">
        <shape android:shape="oval"><solid android:color="#000000"/></shape>
    </item>
</layer-list>
