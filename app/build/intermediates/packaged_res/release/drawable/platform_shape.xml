<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom 3D shadow (0px 6px offset emulated) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#006400" /> <!-- Dark Green -->
        </shape>
    </item>
    
    <!-- Top Highlight (Inset 4px emulated) -->
    <item android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#B3FE66" /> <!-- LawnGreen + White -->
        </shape>
    </item>
    
    <!-- Main Gradient Body -->
    <item android:top="4dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:startColor="#7CFC00"
                android:endColor="#32CD32"
                android:angle="270" />
        </shape>
    </item>
</layer-list>
