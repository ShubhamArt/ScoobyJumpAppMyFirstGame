<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Wrap the layout in a ScrollView so it doesn't get cut off on smaller screens -->
    <ScrollView
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_popup_dialog"
        android:backgroundTint="#151520"
        android:fillViewport="true"
        android:scrollbars="none">

        <!-- Actual Dialog Panel -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:paddingBottom="24dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY REWARD"
                android:textColor="#E040FB"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Claim power-ups and start jumping!"
                android:textColor="#D0D0E0"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/main_gift_icon"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/ic_mystery_box"
                android:layout_marginTop="8dp"
                android:scaleType="centerInside"
                app:layout_constraintTop_toBottomOf="@id/subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/subtitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Come back every day to\nclaim amazing rewards!"
                android:textColor="#D0D0E0"
                android:textSize="14sp"
                android:textAlignment="center"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/main_gift_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Grid for Days 1-6 -->
            <GridLayout
                android:id="@+id/days_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:layout_marginTop="16dp"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false"
                app:layout_constraintTop_toBottomOf="@id/subtitle2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                
                <!-- Day 1 -->
                <LinearLayout android:id="@+id/day_1_panel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@drawable/bg_glass_pill" android:backgroundTint="#2C2C40" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/day_1_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DAY 1" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_coin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 50" android:textColor="#FFC107" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Day 2 -->
                <LinearLayout android:id="@+id/day_2_panel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@drawable/bg_glass_pill" android:backgroundTint="#2C2C40" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/day_2_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DAY 2" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_coin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 100" android:textColor="#FFC107" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Day 3 -->
                <LinearLayout android:id="@+id/day_3_panel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@drawable/bg_glass_pill" android:backgroundTint="#2C2C40" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/day_3_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DAY 3" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_coin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 150" android:textColor="#FFC107" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Day 4 -->
                <LinearLayout android:id="@+id/day_4_panel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@drawable/bg_glass_pill" android:backgroundTint="#2C2C40" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/day_4_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DAY 4" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_coin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 200" android:textColor="#FFC107" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Day 5 -->
                <LinearLayout android:id="@+id/day_5_panel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@drawable/bg_glass_pill" android:backgroundTint="#2C2C40" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/day_5_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DAY 5" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_coin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 250" android:textColor="#FFC107" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Day 6 -->
                <LinearLayout android:id="@+id/day_6_panel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@drawable/bg_glass_pill" android:backgroundTint="#2C2C40" android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/day_6_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DAY 6" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_coin"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" 300" android:textColor="#FFC107" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </GridLayout>

            <!-- Day 7 Chest -->
            <LinearLayout
                android:id="@+id/day_7_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_cyan_border_panel"
                android:backgroundTint="#3B1C5A"
                android:padding="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/days_grid"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                
                <TextView
                    android:id="@+id/day_7_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAY 7"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="6dp">
                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="50dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/img_chest_box" />
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_coin"
                        android:layout_marginStart="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 500"
                        android:textColor="#FFC107"
                        android:textStyle="bold"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_claim_reward"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:layout_marginTop="16dp"
                android:text="CLAIM"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_start_game_green"
                app:layout_constraintTop_toBottomOf="@id/day_7_panel"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Close button positioned outside the constrained rect using FrameLayout gravity -->
    <ImageButton
        android:id="@+id/btn_close_daily_reward"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_exit_btn"
        android:backgroundTint="#6200EE"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="#FFFFFF"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:elevation="12dp" />

</FrameLayout>
