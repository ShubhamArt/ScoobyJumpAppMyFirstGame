<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1B9E3A"/>
                    <corners android:radius="24dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <!-- 3D Bevel Edge -->
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#116D25"/>
                    <corners android:radius="24dp"/>
                </shape>
            </item>
            <!-- Top Gradient Surface -->
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#2DDE54"
                        android:endColor="#1EAA3C"
                        android:angle="270" />
                    <corners android:radius="24dp"/>
                    <stroke android:width="2dp" android:color="#A5F2B5"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
