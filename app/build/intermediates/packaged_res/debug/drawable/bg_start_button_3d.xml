<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark Green Shadow (Bottom 6dp offset) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#1B8B2C" />
        </shape>
    </item>
    
    <!-- Light Green Highlight (Top 4dp offset) -->
    <item android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#78FAA0" />
        </shape>
    </item>
    
    <!-- Main Vibrant Green Body -->
    <item android:top="4dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#28CD41" />
        </shape>
    </item>
</layer-list>
