<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FBC02D"/>
                    <corners android:radius="16dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <!-- Bevel edge -->
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#F57F17"/>
                    <corners android:radius="16dp"/>
                </shape>
            </item>
            <!-- Top surface -->
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#FFF176"
                        android:endColor="#FFD54F"
                        android:angle="270" />
                    <corners android:radius="16dp"/>
                    <stroke android:width="2dp" android:color="#FFF9C4"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
