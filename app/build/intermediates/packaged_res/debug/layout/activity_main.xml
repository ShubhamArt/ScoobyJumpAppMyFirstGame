<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/root_layout">

    <FrameLayout
        android:id="@+id/game_view_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

    <!-- LAYER 1: Ad Container -->
    <FrameLayout
        android:id="@+id/ad_banner_container"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:elevation="99999dp"
        android:background="#2C3B5E">
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#80FFFFFF"
            android:layout_gravity="top" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AD"
            android:background="#60000000"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:layout_gravity="top|start" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMART BANNER ADVERTISEMENT"
            android:gravity="center"
            android:layout_gravity="center"
            android:textColor="#A0B0D0"
            android:textSize="14sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- LAYER 2: UI Container (Top-most) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/home_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:layout_marginBottom="80dp"
        android:visibility="visible">

        <!-- GLOBAL HEADER CONTAINER -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/settings_button"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="40dp"
                android:layout_marginStart="20dp"
                android:background="@drawable/bg_glass_circle_border"
                android:src="@drawable/ic_speaker_neon"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/help_button_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/help_button"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_glass_circle_border"
                    android:text="?"
                    android:textColor="#E040FB"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black" />
                
                <!-- Removed 'TAP FOR HOW TO PLAY' text per request -->
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_best_score_panel"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_glass_pill"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toStartOf="@id/home_coins_capsule"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_trophy_neon" />
                <TextView
                    android:id="@+id/home_best_score_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="14sp"
                    android:textColor="#FFC107"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/home_coins_capsule"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_coin_capsule_navy"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="16dp"
                app:layout_constraintEnd_toStartOf="@id/help_button_container"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/home_coin_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_coin" />
                <TextView
                    android:id="@+id/home_coins_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="#000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="1.5" />
            </LinearLayout>

            <!-- BRAND IDENTITY -->
            <LinearLayout
                android:id="@+id/brand_identity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="10dp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/home_coins_capsule">

                <com.game.scoobyjump.BubbleTextView
                    android:id="@+id/title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCOOBY JUMP"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/subtitle_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Land on platforms • Collect coins"
                    android:textColor="#B2FFD6"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:shadowColor="#000000"
                    android:shadowDx="1.5"
                    android:shadowDy="1.5"
                    android:shadowRadius="1.5"
                    android:layout_marginTop="24dp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Vertical Spacing Removed in favor of strict margin-anchoring -->

        <!-- Vertical Spacing Removed in favor of strict margin-anchoring -->
        <!-- POWER UPS DOCK (Horizontal layout, Bottom) -->
        <!-- INTERACTIVE POWER-UP LOADOUT BAR -->
        <LinearLayout
            android:id="@+id/btn_power_ups_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_glass_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottom_controls">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POWER UP LOADOUT"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <!-- SHIELD MODULE -->
                <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                    <ImageView android:id="@+id/icon_upgrade_shield" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_shield_powerup" />
                    <TextView android:id="@+id/btn_upgrade_shield" android:layout_width="14dp" android:layout_height="14dp" android:text="+" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_start_game_green" android:layout_gravity="bottom|end" android:layout_marginBottom="-4dp" android:layout_marginEnd="-4dp" android:elevation="4dp"/>
                </FrameLayout>

                <!-- MAGNET MODULE -->
                <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp">
                    <ImageView android:id="@+id/icon_upgrade_magnet" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_magnet_powerup" />
                    <TextView android:id="@+id/btn_upgrade_magnet" android:layout_width="14dp" android:layout_height="14dp" android:text="+" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_start_game_green" android:layout_gravity="bottom|end" android:layout_marginBottom="-4dp" android:layout_marginEnd="-4dp" android:elevation="4dp"/>
                </FrameLayout>
                
                <!-- LIGHTNING (JETPACK) MODULE -->
                <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp">
                    <ImageView android:id="@+id/icon_upgrade_lightning" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_powerups_3d" />
                    <TextView android:id="@+id/btn_upgrade_lightning" android:layout_width="14dp" android:layout_height="14dp" android:text="+" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_start_game_green" android:layout_gravity="bottom|end" android:layout_marginBottom="-4dp" android:layout_marginEnd="-4dp" android:elevation="4dp"/>
                </FrameLayout>

            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/player_preview_wrapper"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/header_container"
            app:layout_constraintBottom_toTopOf="@id/play_button">
            <FrameLayout
                android:id="@+id/player_preview_halo"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_halo_glow" />
            <FrameLayout
                android:id="@+id/player_preview_image"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_player_preview"/>
        </FrameLayout>

        <Button
            android:id="@+id/play_button"
            android:layout_width="260dp"
            android:layout_height="64dp"
            android:layout_marginBottom="24dp"
            android:text="START GAME"
            android:textColor="@color/ui_yellow"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:shadowColor="@color/scooby_brown"
            android:shadowDx="2"
            android:shadowDy="4"
            android:shadowRadius="1.5"
            android:background="@drawable/bg_start_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btn_power_ups_info" />

        <LinearLayout
            android:id="@+id/bottom_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_glass_dock"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageButton
                        android:id="@+id/shop_button"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_icon"
                        android:src="@drawable/ic_hero_mask"
                        android:padding="14dp"
                        android:scaleType="fitCenter"/>
                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_exit_btn"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:elevation="4dp"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="HEROES"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="#000000"
                    android:shadowDx="1.5"
                    android:shadowDy="1.5"
                    android:shadowRadius="1"
                    android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:gravity="center">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageButton
                        android:id="@+id/missions_button"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_icon"
                        android:src="@drawable/ic_mission_clipboard"
                        android:padding="14dp"
                        android:scaleType="fitCenter"/>
                    <TextView
                        android:id="@+id/missions_badge"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_exit_btn"
                        android:text="!"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="0dp"
                        android:layout_marginEnd="0dp"
                        android:elevation="6dp"
                        android:visibility="gone"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="MISSIONS"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="#000000"
                    android:shadowDx="1.5"
                    android:shadowDy="1.5"
                    android:shadowRadius="1"
                    android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/leaderboard_button"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_glass_icon"
                    android:src="@drawable/ic_trophy_neon"
                    android:padding="14dp"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="RANKING"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="#000000"
                    android:shadowDx="1.5"
                    android:shadowDy="1.5"
                    android:shadowRadius="1"
                    android:textSize="10sp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/btn_daily_reward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/daily_reward_icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_icon"
                        android:src="@drawable/ic_mystery_box"
                        android:padding="14dp"
                        android:scaleType="fitCenter"/>
                    <View
                        android:id="@+id/daily_reward_notification_dot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_red_dot"
                        android:elevation="4dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="0dp"
                        android:layout_marginEnd="0dp" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="DAILY REWARD"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="#000000"
                    android:shadowDx="1.5"
                    android:shadowDy="1.5"
                    android:shadowRadius="1"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- IN-GAME HUD -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/hud_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/hud_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text=" 0"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:shadowColor="@color/black"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="5"
            android:gravity="center_vertical"
            app:drawableStartCompat="@drawable/ic_score_star"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/hud_coins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:text=" 0"
            android:textColor="#FFBF00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:shadowColor="@color/black"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="5"
            android:gravity="center_vertical"
            app:drawableStartCompat="@drawable/ic_coin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/hud_score" />

        <Button
            android:id="@+id/pause_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="24dp"
            android:text="II"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- GHOST SPIRIT METER -->
        <LinearLayout
            android:id="@+id/spirit_meter_container"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:gravity="end"
            app:layout_constraintEnd_toEndOf="@id/pause_button"
            app:layout_constraintTop_toBottomOf="@id/pause_button">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPIRIT METER"
                android:textColor="#E040FB"
                android:textSize="10sp"
                android:textStyle="bold"
                android:shadowColor="#FF000000"
                android:shadowDx="1" 
                android:shadowDy="1" 
                android:shadowRadius="2" />
                
            <ProgressBar
                android:id="@+id/hud_spirit_meter"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#E040FB"
                android:progressBackgroundTint="#40FFFFFF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- OVERDRIVE ACTIVATE BUTTON -->
        <Button
            android:id="@+id/btn_trigger_overdrive"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="GHOST SPRINT"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:backgroundTint="#AA000000"
            app:strokeColor="#E040FB"
            app:strokeWidth="2dp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="@id/pause_button"
            app:layout_constraintTop_toBottomOf="@id/spirit_meter_container"/>

        <!-- SPAWN POSSESSED PLATFORM BUTTON -->
        <Button
            android:id="@+id/btn_spawn_possessed"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="SUMMON POSSESSED"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:backgroundTint="#AA000000"
            app:strokeColor="#FFC107"
            app:strokeWidth="2dp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="@id/pause_button"
            app:layout_constraintTop_toBottomOf="@id/btn_trigger_overdrive"/>

        <!-- NEW MISSION HUD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/hud_mission_card"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#CC1E2A38"
            app:strokeColor="#4A6A8A"
            app:strokeWidth="1dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="12dp"
            app:layout_constraintEnd_toStartOf="@id/pause_button"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="gone">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                <TextView
                    android:id="@+id/hud_mission_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Mission"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
                <ProgressBar
                    android:id="@+id/hud_mission_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="4dp"
                    android:progressTint="#00E5FF"
                    android:progressBackgroundTint="#3300E5FF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- REVIVE COUNTDOWN OVERLAY -->
    <TextView
        android:id="@+id/tv_countdown_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:background="#99000000"
        android:text="3"
        android:textColor="#FFFFFF"
        android:textSize="120sp"
        android:textStyle="bold"
        android:shadowColor="#FFFFFF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="30"
        android:visibility="gone"
        android:elevation="100dp" />

    <!-- AD LOADING OVERLAY -->
    <FrameLayout
        android:id="@+id/ad_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:elevation="99999dp"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#00E5FF" />
    </FrameLayout>

</FrameLayout>
