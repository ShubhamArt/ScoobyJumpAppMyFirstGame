<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:clipChildren="true"
    android:clipToPadding="true"
    android:background="@drawable/bg_mission_panel"
    android:padding="24dp">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DAILY MISSIONS"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:shadowColor="#00E5FF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="10" />

    <View
        android:id="@+id/title_divider"
        android:layout_width="160dp"
        android:layout_height="2dp"
        android:layout_marginTop="8dp"
        android:layout_gravity="center_horizontal"
        android:background="#00FFFF" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/missions_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="380dp"
        android:layout_marginTop="24dp"
        android:clipToPadding="true"
        android:clipChildren="true" />

    <LinearLayout
        android:id="@+id/mission_action_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">
        
        <Button
            android:id="@+id/btn_close_missions"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="CLOSE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_action_btn" />
    </LinearLayout>

</LinearLayout>
