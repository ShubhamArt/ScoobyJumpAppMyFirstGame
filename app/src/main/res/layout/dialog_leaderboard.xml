<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/bg_mission_panel"
    android:padding="24dp">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Leaderboard"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:shadowColor="#00E5FF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="10"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/title_divider"
        android:layout_width="160dp"
        android:layout_height="2dp"
        android:layout_marginTop="8dp"
        android:background="#00FFFF"
        app:layout_constraintTop_toBottomOf="@id/dialog_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toBottomOf="@id/title_divider">

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="RNK"
            android:textColor="#A0B0D0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="HERO"
            android:textColor="#A0B0D0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="SCORE / STATS"
            android:textColor="#A0B0D0"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/leaderboard_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="350dp"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@android:color/white"
        android:layout_marginTop="8dp"
        android:clipToPadding="true"
        android:clipChildren="true"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/header_row"
        app:layout_constraintBottom_toTopOf="@id/global_coming_soon" />

    <TextView
        android:id="@+id/global_coming_soon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Global Leaderboards Coming Soon..."
        android:textColor="#88FFFFFF"
        android:textSize="12sp"
        android:textStyle="italic"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/leaderboard_recycler_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/leaderboard_action_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/global_coming_soon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <Button
            android:id="@+id/btn_close_leaderboard"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="CLOSE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_action_btn" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
