<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_popup_dialog">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CASE SOLVED!"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/dialog_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose a mystery folder"
        android:textColor="#A0B0D0"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <FrameLayout
            android:id="@+id/folder_1"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginEnd="8dp">
            <ImageView
                android:id="@+id/img_folder_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_folder"/>
            <TextView
                android:id="@+id/reward_text_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="100"
                android:textColor="#FFBF00"
                android:textStyle="bold"
                android:textSize="18sp"
                android:visibility="gone"/>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/folder_2"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp">
            <ImageView
                android:id="@+id/img_folder_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_folder"/>
            <TextView
                android:id="@+id/reward_text_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="50"
                android:textColor="#FFBF00"
                android:textStyle="bold"
                android:textSize="18sp"
                android:visibility="gone"/>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/folder_3"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="8dp">
            <ImageView
                android:id="@+id/img_folder_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_folder"/>
            <TextView
                android:id="@+id/reward_text_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="200"
                android:textColor="#FFBF00"
                android:textStyle="bold"
                android:textSize="18sp"
                android:visibility="gone"/>
        </FrameLayout>
    </LinearLayout>


    <Button
        android:id="@+id/btn_claim_close"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="COLLECT &amp; CLOSE"
        android:textColor="#000000"
        android:textStyle="bold"
        android:background="@drawable/bg_yellow_gradient_btn"
        android:visibility="gone"/>

</LinearLayout>
