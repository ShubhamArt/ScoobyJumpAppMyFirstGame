<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#8A5A00" /> <!-- Core shadow -->
        </shape>
    </item>
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient android:startColor="#FFD700" android:endColor="#FF8C00" android:angle="270" />
            <stroke android:width="1dp" android:color="#FFF17A" />
        </shape>
    </item>
</layer-list>
